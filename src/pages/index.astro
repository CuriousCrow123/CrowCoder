---
import Base from "../layouts/Base.astro";
import ProseHighlight from "../components/ProseHighlight.svelte";
import ProseReactive from "../components/ProseReactive.svelte";
import ColorPicker from "../components/ColorPicker.svelte";
import Popup from "../components/Popup.svelte";
import QuizPopup from "../components/QuizPopup.svelte";
import Hint from "../components/Hint.svelte";
import ProgressBar from "../components/ProgressBar.svelte";
import ExportImport from "../components/ExportImport.svelte";
import ReviewBanner from "../components/ReviewBanner.svelte";

const quizIds = [
  "color-primary",
  "color-secondary",
  "color-complementary",
  "color-warm-cool",
];
---

<Base title="Color Theory — CrowCoder">
  <main id="main-content" class="prose-column" style="padding-block: 3rem;">
    <h1>Understanding Color Theory</h1>

    <ReviewBanner client:load />
    <ProgressBar client:load quizIds={quizIds} />

    <p>
      Color theory is the foundation of visual design. It explains how colors
      interact, how they can be combined harmoniously, and how they affect
      human perception and emotion.
    </p>

    <h2>Primary Colors</h2>
    <p>
      In the traditional color model, the three primary colors are
      <strong>red</strong>, <strong>yellow</strong>, and <strong>blue</strong>.
      These colors cannot be created by mixing other colors together — they are
      the building blocks from which all other colors are derived.
    </p>

    <div id="quiz-color-primary">
      <QuizPopup
        client:visible
        id="color-primary"
        question="Which of these is NOT a primary color in the traditional color model?"
        answers={["Red", "Green", "Blue", "Yellow"]}
        correctIndex={1}
      />
    </div>

    <h2>The Color Wheel</h2>
    <p>
      The color wheel arranges colors in a circle, showing relationships
      between primary, secondary, and tertiary colors. Try
      <ProseHighlight client:load id="color-main">selecting a color on the wheel below</ProseHighlight>
      to explore how hues relate to each other. Secondary colors
      (orange, green, purple) are made by mixing two primaries.
    </p>

    <div class="component-breakout interactive-section">
      <ColorPicker client:load id="main" />
    </div>

    <p>
      <ProseReactive client:load>
        You're currently exploring the color wheel. Drag the handle to
        discover different hues and see how they relate to the prose above.
      </ProseReactive>
    </p>

    <div id="quiz-color-secondary">
      <QuizPopup
        client:visible
        id="color-secondary"
        question="What do you get when you mix red and yellow?"
        answers={["Green", "Purple", "Orange", "Brown"]}
        correctIndex={2}
      />
    </div>

    <h2>Color Harmony</h2>
    <p>
      Colors that look good together follow predictable patterns on the
      color wheel.
      <ProseHighlight client:load id="color-main">Complementary colors</ProseHighlight>
      sit opposite each other (like blue and orange).
      <strong>Analogous</strong> colors are neighbors (like blue, blue-green,
      and green). <strong>Triadic</strong> colors form an equilateral triangle
      on the wheel.
    </p>

    <Popup client:visible id="color-complementary-hint" trigger="manual" mode="inline">
      <Hint title="Did you know?">
        <p>
          Complementary color pairs create maximum contrast. That's why
          sports teams often use them — the colors pop against each other
          and are easy to distinguish from a distance.
        </p>
      </Hint>
    </Popup>

    <div id="quiz-color-complementary">
      <QuizPopup
        client:visible
        id="color-complementary"
        question="What is the complementary color of blue?"
        answers={["Red", "Green", "Orange", "Yellow"]}
        correctIndex={2}
        mode="modal"
      />
    </div>

    <h2>Warm vs. Cool Colors</h2>
    <p>
      The color wheel splits into warm colors (reds, oranges, yellows) and
      cool colors (blues, greens, purples). Warm colors advance visually
      and feel energetic. Cool colors recede and feel calming. Understanding
      this distinction is key to creating mood and depth in design.
    </p>

    <Popup client:visible id="warm-cool-hint" trigger="manual" mode="slide-in">
      <Hint title="Color temperature">
        <p>
          Artists use warm and cool colors strategically. Warm foreground
          colors make objects "pop," while cool background colors create
          depth. This is why distant mountains look blue — atmospheric
          perspective shifts colors toward the cool end of the spectrum.
        </p>
      </Hint>
    </Popup>

    <div id="quiz-color-warm-cool">
      <QuizPopup
        client:visible
        id="color-warm-cool"
        question="Which color is considered a 'warm' color?"
        answers={["Blue", "Purple", "Green", "Orange"]}
        correctIndex={3}
      />
    </div>

    <p>
      Try clicking the
      <ProseHighlight client:load id="color-main">highlighted text</ProseHighlight>
      throughout this page to see how prose and components communicate
      bidirectionally — the text highlights the component, and interacting
      with the component highlights related text.
    </p>

    <h2>Keep Learning</h2>
    <p>
      Color theory is a foundation you'll build on throughout your design
      journey. Review the quizzes above as they become due — spaced
      repetition helps concepts move from short-term to long-term memory.
      Use the dark mode toggle in the top-right corner to study in your
      preferred lighting. Your progress is saved automatically and can be
      exported below.
    </p>

    <h2>Your Progress</h2>
    <div class="component-breakout">
      <ExportImport client:idle />
    </div>
  </main>
</Base>
